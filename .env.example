# Copy this to .env for local dev. Never commit .env.

# Django
DJANGO_SETTINGS_MODULE=smartytask.settings.dev
SECRET_KEY=change-me-to-a-long-random-string-for-local-only
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# Database — local Postgres
DATABASE_URL=postgres://smartytask:smartytask@localhost:5432/smartytask

# Email — Brevo SMTP (production); console backend in dev
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
# EMAIL_HOST=smtp-relay.brevo.com
# EMAIL_PORT=587
# EMAIL_HOST_USER=your-brevo-smtp-login
# EMAIL_HOST_PASSWORD=your-brevo-smtp-password
# DEFAULT_FROM_EMAIL=Donny <hello@smartytask.com>

# Stripe — leave blank in dev unless testing checkout
STRIPE_PUBLISHABLE_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Email-to-inbox domain
INBOX_EMAIL_DOMAIN=inbox.smartytask.com
